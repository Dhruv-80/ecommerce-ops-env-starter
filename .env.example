# ─── HuggingFace Inference (optional, for the live demo client) ─────────────
API_BASE_URL=https://router.huggingface.co/v1
HF_TOKEN=replace_me

# ─── Local environment server ───────────────────────────────────────────────
ENV_BASE_URL=http://localhost:7860

# ─── Training (HF Jobs) ─────────────────────────────────────────────────────
# Repo cloned at runtime so the training script can `import environment` etc.
ENV_REPO_URL=https://github.com/Dhruv-80/ecommerce-ops-env-starter.git

# Push targets — change YOUR_USERNAME to your HF handle.
HUB_MODEL_REPO=YOUR_USERNAME/commerce-ops-grpo
HUB_RESULTS_REPO=YOUR_USERNAME/commerce-ops-results

# Smaller, cost-tuned base model. Switch to Qwen/Qwen2.5-3B-Instruct only if
# you have ample HF Jobs credit; on a $7 budget the 1.5B variant trains the
# simplified T1/T2/T3 well within the 2-hour deadline.
MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

# 80 GRPO steps is enough for the simplified tasks to converge on l4x1.
# Bump to 150–200 if you have credit for a longer run.
TRAIN_STEPS=80
FAST_DEV=0

# Cheapest GPU flavor on HF Jobs that fits 1.5B 4-bit + LoRA comfortably.
# Use h200 only if you've already paid for it and want maximum throughput.
HF_FLAVOR=l4x1
HF_TIMEOUT=2h
