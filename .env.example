# ─── HuggingFace Inference (optional, for the live demo client) ─────────────
API_BASE_URL=https://router.huggingface.co/v1
HF_TOKEN=replace_me

# ─── Local environment server ───────────────────────────────────────────────
ENV_BASE_URL=http://localhost:7860

# ─── Training (HF Jobs) ─────────────────────────────────────────────────────
# Repo cloned at runtime so the training script can `import environment` etc.
ENV_REPO_URL=https://github.com/Dhruv-80/ecommerce-ops-env-starter.git

# Push targets.
HUB_MODEL_REPO=Gloomytarsier3/ecommerce-ops-grpo
HUB_RESULTS_REPO=Gloomytarsier3/ecommerce-ops-results

# Base model for GRPO fine-tuning.
MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

# GRPO training steps and fast-dev flag.
TRAIN_STEPS=80
FAST_DEV=0

# HF Jobs flavor and timeout.
HF_FLAVOR=l4x1
HF_TIMEOUT=2h
